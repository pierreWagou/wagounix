{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Container images in Nix service files",
      "managerFilePatterns": ["hosts/nixos/wagoulab/services/**/*.nix"],
      "matchStrings": [
        "image\\s*=\\s*\"(?<depName>[^:\"$]+):(?<currentValue>[^\"$]+)\""
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Immich version variable (drives both server and ML images)",
      "managerFilePatterns": ["hosts/nixos/wagoulab/services/immich.nix"],
      "matchStrings": [
        "immichVersion\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "ghcr.io/immich-app/immich-server",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Renovate CLI image in podman run command",
      "managerFilePatterns": ["hosts/nixos/wagoulab/services/renovate.nix"],
      "matchStrings": [
        "ghcr\\.io/renovatebot/renovate:(?<currentValue>[^\\s\"]+)"
      ],
      "depNameTemplate": "ghcr.io/renovatebot/renovate",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Authentik version variable (drives both server and worker images)",
      "managerFilePatterns": ["hosts/nixos/wagoulab/services/authentik.nix"],
      "matchStrings": [
        "authentikVersion\\s*=\\s*\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "ghcr.io/goauthentik/server",
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "description": "Valkey image version in variables.nix (shared by immich-redis, authentik-redis, seafile-redis)",
      "managerFilePatterns": ["hosts/nixos/wagoulab/variables.nix"],
      "matchStrings": [
        "valkeyImage\\s*=\\s*\"(?<depName>[^:\"$]+):(?<currentValue>[^\"$]+)\""
      ],
      "datasourceTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "description": "Automerge minor, patch, and digest updates",
      "matchUpdateTypes": ["minor", "patch", "digest"],
      "automerge": true
    },
    {
      "description": "Group all Nix flake lock maintenance into a single PR",
      "matchManagers": ["nix"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "nix flake lock",
      "automerge": true
    },
    {
      "description": "Immich updates require manual review (coupled server + ML)",
      "matchPackagePatterns": ["immich-app/"],
      "groupName": "immich",
      "automerge": false
    },
    {
      "description": "Authentik updates require manual review (coupled server + worker images)",
      "matchPackagePatterns": ["goauthentik/"],
      "groupName": "authentik",
      "automerge": false
    }
  ]
}
